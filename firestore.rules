rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- FUNCIONES DE AYUDA (Helpers) ---
    
    // Verifica si el usuario autenticado pertenece a la colección de personal
    function isStaff() {
      return request.auth != null && exists(/databases/$(database)/documents/staff/$(request.auth.uid));
    }
    
    // Verifica si el usuario es específicamente Administrador
    function isAdmin() {
      return isStaff() && get(/databases/$(database)/documents/staff/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Verifica si el usuario es dueño del documento
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // --- REGLAS POR COLECCIÓN ---

    // Colección de Pacientes (Usuarios)
    match /users/{userId} {
      // Lectura y Escritura: El propio paciente o cualquier miembro del staff
      allow read, create, update: if isOwner(userId) || isStaff();
      allow delete: if isAdmin(); // Solo el administrador puede borrar pacientes
    }
    
    // Colección de Personal (Staff)
    match /staff/{staffId} {
      // El primer acceso permite creación, luego controlado por la app
      allow create: if request.auth != null;
      
      // PERMISOS DE LECTURA:
      // Un médico puede ver su propio perfil.
      // Un miembro del staff puede ver la lista de sus colegas (necesario para Configuración).
      allow read: if isOwner(staffId) || isStaff();
      
      // PERMISOS DE ACTUALIZACIÓN:
      // Solo el dueño del perfil o un Administrador pueden hacer cambios
      allow update: if isOwner(staffId) || isAdmin();
      
      allow delete: if isAdmin();
    }
    
    // Colección de Citas
    match /appointments/{appointmentId} {
      // Creación: El paciente para sí mismo o el staff para cualquier paciente
      allow create: if request.auth != null && 
        (request.resource.data.userId == request.auth.uid || isStaff());
      
      // Gestión: Dueño de la cita o miembros del staff
      allow read, update, delete: if isOwner(resource.data.userId) || isStaff();
      
      // Permitir lectura general para validación de disponibilidad de horarios
      allow read: if request.auth != null;
    }
    
    // Colección de Notificaciones
    match /notifications/{notificationId} {
      // Solo el staff crea notificaciones
      allow create: if isStaff();
      
      // Lectura/Actualización: El personal médico o el paciente al que va dirigida
      allow read, update: if isStaff() || (request.auth != null && resource.data.userId == request.auth.uid);
      
      allow delete: if isStaff();
    }
  }
}
